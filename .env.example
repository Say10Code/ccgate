# ccgate — LLM Cost Proxy Configuration

# Proxy server port
CCGATE_PORT=4100

# Data directory for SQLite database and logs
CCGATE_DATA_DIR=$HOME/.ccgate

# Daily spending limit (USD)
CCGATE_DAILY_BUDGET=5.00

# Monthly spending limit (USD)
CCGATE_MONTHLY_BUDGET=50.00

# Log output format: "pretty" (colorful console) or "json" (JSON Lines)
CCGATE_LOG_FORMAT=pretty

# DeepSeek API endpoint (Anthropic-compatible)
# Default: https://api.deepseek.com/anthropic
CCGATE_UPSTREAM_URL=https://api.deepseek.com/anthropic

# ⚠  Claude Code configuration (settings.json):
